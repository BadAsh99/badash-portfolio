LLMGUARDT2_INTERNAL_URL=http://localhost:5000

# GitHub token for higher API rate limits (optional but recommended)
GITHUB_TOKEN=ghp_...

# Public site URL
NEXT_PUBLIC_SITE_URL=https://badash99.dev
